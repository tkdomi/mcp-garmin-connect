# Garmin Connect credentials
GARMIN_EMAIL=your@email.com
GARMIN_PASSWORD=yourpassword

# Supabase (optional — enables response caching)
# SUPABASE_URL=https://your-project.supabase.co
# SUPABASE_KEY=your-service-role-key

# n8n webhooks (optional — enables health alerts)
# N8N_WEBHOOK_URL=https://your-n8n.example.com/webhook/health
# N8N_BEARER_TOKEN=your-bearer-token

# Optional — MCP server
MCP_PORT=8080
SYNC_HOUR=7
SYNC_MINUTE=0
CACHE_TTL_DAILY=1
CACHE_TTL_HISTORICAL=24

# Optional — alert thresholds
ALERT_BODY_BATTERY_WARNING=40
ALERT_BODY_BATTERY_CRITICAL=20
ALERT_SLEEP_SCORE_WARNING=65
ALERT_SLEEP_SCORE_CRITICAL=50
ALERT_STRESS_WARNING=60
ALERT_STRESS_CRITICAL=75
ALERT_STEPS_WARNING=5000
ALERT_STEPS_CRITICAL=2000
